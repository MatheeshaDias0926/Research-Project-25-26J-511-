{
  "name": "smart-bus-backend",
  "version": "1.0.0",
  "description": "Backend for Sri Lanka Smart Bus Safety Project",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "ml": "bash ../ML_model_PassP/start_ml_service.sh",
    "dev:all": "concurrently \"npm run dev\" \"npm run ml\"",
    "seed": "node seed.js"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0"
  },
  "nodemonConfig": {
    "ignore": [
      "cache/*",
      "*.log"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.2"
  }
}
