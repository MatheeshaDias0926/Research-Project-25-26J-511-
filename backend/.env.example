# Backend Environment Variables
# Copy this file to .env and fill in the values

# Database (MongoDB Atlas for production, localhost for dev)
MONGO_URI=mongodb://localhost:27017/smartBusDB
# MONGO_URI=mongodb+srv://smartbus_app:<password>@cluster0.xxxxx.mongodb.net/smartBusDB

# Authentication
JWT_SECRET=your-jwt-secret-change-this-to-random-32-char-string
JWT_EXPIRE=30d

# Server
PORT=3000
NODE_ENV=development

# ML Service (occupancy predictions — runs on same server)
ML_SERVICE_URL=http://localhost:5001

# IoT Security (set this to require X-API-Key header from ESP32)
# Leave blank/unset to allow all requests (dev mode)
# IOT_API_KEY=your-random-api-key-for-esp32

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*
