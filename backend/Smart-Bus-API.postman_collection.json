    {
      "name": "Bus",
      "item": [
        {
          "name": "Get All Buses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bus",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bus"]
            }
          }
        },
        {
          "name": "Create Bus (Authority)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"licensePlate\": \"TEST-123\",\n  \"capacity\": 55,\n  \"routeId\": \"ROUTE-999\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/bus",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bus"]
            }
          }
        },
        {
          "name": "Get Bus by License Plate",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bus/plate/NP-1234",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bus", "plate", "NP-1234"]
            }
          }
        },
        {
          "name": "Get Bus Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bus/{{busId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bus", "{{busId}}", "status"]
            }
          }
        },
        {
          "name": "Get Bus Violations (Authority)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bus/{{busId}}/violations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bus", "{{busId}}", "violations"]
            }
          }
        },
        {
          "name": "Get Bus Data Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bus/{{busId}}/logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bus", "{{busId}}", "logs"]
            }
          }
        },
        {
          "name": "Get ML Prediction (Passenger)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bus/predict/ROUTE-138",
              "host": ["{{baseUrl}}"],
              "path": ["api", "bus", "predict", "ROUTE-138"]
            }
          }
        }
      ]
    },
    {
      "name": "Maintenance",
      "item": [
        {
          "name": "Create Maintenance Log",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"busId\": \"{{busId}}\",\n  \"issue\": \"Brake system malfunction\",\n  \"description\": \"Front left brake not responding properly\",\n  \"priority\": \"high\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/maintenance",
              "host": ["{{baseUrl}}"],
              "path": ["api", "maintenance"]
            }
          }
        },
        {
          "name": "Get All Maintenance Logs (Authority)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/maintenance",
              "host": ["{{baseUrl}}"],
              "path": ["api", "maintenance"]
            }
          }
        },
        {
          "name": "Get Maintenance Logs by Bus",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/maintenance/bus/{{busId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "maintenance", "bus", "{{busId}}"]
            }
          }
        },
        {
          "name": "Get Maintenance Log by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/maintenance/{{logId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "maintenance", "{{logId}}"]
            }
          }
        },
        {
          "name": "Update Maintenance Log",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in-progress\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/maintenance/{{logId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "maintenance", "{{logId}}"]
            }
          }
        },
        {
          "name": "Delete Maintenance Log (Authority)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/maintenance/{{logId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "maintenance", "{{logId}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "busId",
      "value": "",
      "type": "string"
    },
    {
      "key": "logId",
      "value": "",
      "type": "string"
    }
  ]
}
