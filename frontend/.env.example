# Smart Bus Safety System - Frontend Environment Variables

# API Base URL (default: proxied through Vite to http://localhost:3000)
# Uncomment and modify if your backend is running on a different host/port
# VITE_API_URL=http://localhost:3000/api

# ML Service URL (optional, if you want to call ML service directly)
# VITE_ML_SERVICE_URL=http://localhost:5001
